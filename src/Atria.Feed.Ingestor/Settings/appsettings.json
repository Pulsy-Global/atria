{
  "KestrelPort": 5010,
  "Serilog": {
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "System.Net.Http": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:dd-MM-yyyy HH:mm:ss} [{Level:u3}] ({SourceContext}) [{ThreadId}]{NewLine}{Message}{NewLine}{Exception}",
          "restrictedToMinimumLevel": "Information"
        }
      }
    ]
  },
  "Messaging": {
    "Url": "nats://localhost:4222",
    "Username": "natsadmin",
    "Password": "natsadmin",
    "ServiceName": "Atria.Feed.Ingestor",
    "KVBucketName": "ingestor-ethereum-mainnet"
  },
  "Ingestor" : {
    "EnableRealtimeIngestion": true,
    "NetworkId": "ethereum-mainnet",
    "HttpClient": {
      "OnReorgHeaders": {
        "X-ERPC-Skip-Cache-Read": "true",
        "X-W12-Skip-Cache-Read": "true"
      }
    }
  }
}

