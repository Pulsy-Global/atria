{
  "KestrelPort": 4300,
  "Serilog": {
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Information",
        "System": "Warning",
        "System.Net.Http": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:dd-MM-yyyy HH:mm:ss} [{Level:u3}] ({SourceContext}) [{ThreadId}]{NewLine}{Message}{NewLine}{Exception}",
          "restrictedToMinimumLevel": "Information"
        }
      }
    ]
  },
  "AllowedOrigins": "http://localhost:4200,http://localhost:7150",
  "ConnectionStrings": {
    "AtriaConnection": "Host=localhost;Database=Atria;Username=Atria;Password=Atria;Maximum Pool Size=100"
  },
  "Swagger": {
    "EnabledAreas": [
      "MainAPI"
    ]
  },
  "AutoMigrationEnabled": true,
  "Messaging": {
    "Url": "nats://localhost:4222",
    "Username": "natsadmin",
    "Password": "natsadmin",
    "ServiceName": "Atria.Core.Api"
  },
  "Orchestrator" : {
    "DeployStuckIntervalSec": 300,
    "HealthCheckIntervalSec": 60,
    "Provisioning": {
      "Enabled": false,
      "PoolingIntervalSec": 30,
      "FeedsDirectory" : "feeds",
      "OutputsDirectory" : "connections"
    }
  },
  "FileStorage": {
    "FilterPath": "filters",
    "FunctionPath": "functions"
  },
  "FileSystem": {
    "Type": "Local",
    "Local": {
      "BasePath": "../../data/uploads"
    },
    "S3": {
      "Endpoint": null,
      "BucketName": null,
      "AccessKey": null,
      "SecretKey": null
    }
  },
  "Ekv": {
    "Endpoint": "http://localhost:8080"
  }
}
