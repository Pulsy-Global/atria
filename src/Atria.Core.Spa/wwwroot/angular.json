{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "dashboard": {
            "projectType": "application",
            "schematics": {
                "@schematics/angular:component": {
                    "style": "scss"
                }
            },
            "root": "",
            "sourceRoot": "",
            "prefix": "app",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:application",
                    "options": {
                        "outputPath": "misc/dist/dashboard",
                        "index": "shared/index.html",
                        "browser": "shared/main.ts",
                        "polyfills": ["zone.js"],
                        "tsConfig": "tsconfig.app.json",
                        "inlineStyleLanguage": "scss",
                        "allowedCommonJsDependencies": [
                            "apexcharts",
                            "crypto-js/enc-utf8",
                            "crypto-js/hmac-sha256",
                            "crypto-js/enc-base64",
                            "quill-delta"
                        ],
                        "assets": [
                            {
                                "glob": "**/*",
                                "input": "public"
                            },
                            {
                                "glob": "**/*",
                                "input": "shared",
                                "output": "shared"
                            },
                            {
                                "glob": "_redirects",
                                "input": "/",
                                "output": "/"
                            },
                            {
                                "glob": "**/*",
                                "input": "node_modules/monaco-editor",
                                "output": "/assets/monaco/"
                            }
                        ],
                        "stylePreprocessorOptions": {
                            "includePaths": ["fuse/styles"]
                        },
                        "styles": [
                            "shared/styles/inter-phont.css",
                            "shared/styles/ibm-plex-mono.css",
                            "shared/styles/material-icons.css",
                            "fuse/styles/tailwind.scss",
                            "fuse/styles/themes.scss",
                            "shared/styles/splash-screen.css",
                            "shared/styles/vendors.scss",
                            "fuse/styles/main.scss",
                            "shared/styles/styles.scss",
                            "shared/styles/tailwind.scss"
                        ],
                        "scripts": []
                    },
                    "configurations": {
                        "publish": {
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "3mb",
                                    "maximumError": "5mb"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "75kb",
                                    "maximumError": "90kb"
                                }
                            ],
                            "fileReplacements": [
                                {
                                    "replace": "app/env/environment.ts",
                                    "with": "app/env/environment.publish.ts"
                                }
                            ],
                            "outputHashing": "all"
                        },
                        "localhost": {
                            "fileReplacements": [
                                {
                                    "replace": "app/env/environment.ts",
                                    "with": "app/env/environment.localhost.ts"
                                }
                            ],
                            "optimization": false,
                            "extractLicenses": false,
                            "sourceMap": true
                        }
                    },
                    "defaultConfiguration": "localhost"
                },
                "serve": {
                    "builder": "@angular-devkit/build-angular:dev-server",
                    "configurations": {
                        "publish": {
                            "buildTarget": "dashboard:build:publish"
                        },
                        "localhost": {
                            "buildTarget": "dashboard:build:localhost"
                        }
                    },
                    "defaultConfiguration": "localhost"
                },
                "test": {
                    "builder": "@angular-devkit/build-angular:karma",
                    "options": {
                        "polyfills": ["zone.js", "zone.js/testing"],
                        "tsConfig": "tsconfig.spec.json",
                        "inlineStyleLanguage": "scss",
                        "assets": [
                            {
                                "glob": "**/*",
                                "input": "public"
                            }
                        ],
                        "styles": ["shared/styles/styles.scss"],
                        "scripts": []
                    }
                },
                "lint": {
                    "builder": "@angular-eslint/builder:lint",
                    "options": {
                        "lintFilePatterns": [
                            "shared/**/*.ts",
                            "shared/**/*.html"
                        ],
                        "eslintConfig": "eslint.config.js"
                    }
                }
            }
        }
    },
    "cli": {
        "analytics": false,
        "schematicCollections": [
            "@angular-eslint/schematics"
        ]
    }
}